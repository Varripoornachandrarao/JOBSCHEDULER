# ==============================================================================
# Distributed Job Scheduler - Global Configuration Setup
# ==============================================================================

# Database Persistence Configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scheduler_db?schema=public"

# Redis Cache & Queue Broker configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=""

# Express API Gateway server configurations
PORT=3001
JWT_SECRET="your-development-only-jwt-secret-string"

# Frontend Dashboard configuration (Vite prefix required)
VITE_API_URL="http://localhost:3001"

# Worker Thread Pool settings
WORKER_CONCURRENCY=5
